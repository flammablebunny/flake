 /**
+ * xe_guc_pc_set_oc_freq - Set overclock frequency offset
+ * @pc: The GuC PC
+ * @offset: Frequency offset in MHz above RP0 (0 to disable)
+ *
+ * Sets the GPU overclock ceiling via GuC SLPC parameters 14/15.
+ * The GuC firmware uses this as the new maximum boost target.
+ *
+ * Returns: 0 on success, negative error code on failure.
+ */
+int xe_guc_pc_set_oc_freq(struct xe_guc_pc *pc, u32 offset)
+{
+	u32 target;
+	int ret;
+
+	if (offset > 500)
+		return -EINVAL;
+
+	guard(mutex)(&pc->freq_lock);
+
+	if (!pc->freq_ready)
+		return -EAGAIN;
+
+	target = pc->rp0_freq + offset;
+	pc->oc_freq = offset;
+
+	if (offset) {
+		ret = pc_action_set_param(pc,
+					  SLPC_PARAM_GLOBAL_OC_UNSLICE_FREQ_MHZ,
+					  target);
+		if (ret)
+			return ret;
+
+		ret = pc_action_set_param(pc,
+					  SLPC_PARAM_GLOBAL_OC_SLICE_FREQ_MHZ,
+					  target);
+		if (ret)
+			return ret;
+
+		ret = pc_action_set_param(pc,
+					  SLPC_PARAM_GLOBAL_MAX_GT_UNSLICE_FREQ_MHZ,
+					  target);
+	} else {
+		pc_action_unset_param(pc,
+				      SLPC_PARAM_GLOBAL_OC_UNSLICE_FREQ_MHZ);
+		pc_action_unset_param(pc,
+				      SLPC_PARAM_GLOBAL_OC_SLICE_FREQ_MHZ);
+
+		ret = pc_set_max_freq(pc, pc->rp0_freq);
+	}
+
+	return ret;
+}
+
+/**
+ * xe_guc_pc_get_oc_freq - Get overclock frequency offset
+ * @pc: The GuC PC
+ *
+ * Returns: Current overclock offset in MHz (0 if disabled).
+ */
+u32 xe_guc_pc_get_oc_freq(struct xe_guc_pc *pc)
+{
+	return pc->oc_freq;
+}
+
+/**
  * xe_guc_pc_c_status - get the current GT C state
  * @pc: XE_GuC_PC instance
  */
@@ -863,6 +927,7 @@
